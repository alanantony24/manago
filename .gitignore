# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
# testing
/coverage
# next.js
/.next/
/out/
# production
/build
# misc
.DS_Store
*.pem
tmp-shot.*
tmp-*
# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
# env files (can opt-in for committing if needed)
.env*
!.env.example
# vercel
.vercel
# typescript
*.tsbuildinfo
next-env.d.ts
#drafts
**/draft*.txt

# facility demo photos — hosted in Supabase Storage after `npm run upload-photos`
/public/facility-photos/**
!/public/facility-photos/
!/public/facility-photos/*/
!/public/facility-photos/**/.gitkeep

# local Lighthouse CI reports
/.lighthouseci/

# clerk configuration (can include secrets)
/.clerk/
