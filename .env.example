# Public Supabase project configuration used by the application.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public Mapbox token restricted to the application's deployed domains.
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Seeding only. Never configure this in Vercel or normal CI jobs.
# SUPABASE_SERVICE_ROLE_KEY=

# Authentication variables are intentionally managed by the authentication owner.
