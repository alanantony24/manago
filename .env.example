# Public Supabase project configuration.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public Mapbox token (restrict to your deployed domains).
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Clerk authentication.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Optional path hints (also set in ClerkProvider).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/nearby
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/nearby

# Server-only. Needed for seeding and for submissions / reviews / profile sync.
# Never expose this in the browser or commit a real value.
SUPABASE_SERVICE_ROLE_KEY=
